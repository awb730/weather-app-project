{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "rootDir": ".",
    "outDir": "dist",

    "esModuleInterop": true,
    "moduleResolution": "node10",
    "resolveJsonModule": true,

    "strict": true,
    "skipLibCheck": true,
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
